@* Change this to your PaginatedList type or keep as IEnumerable if using ViewBag for paging *@
@model IEnumerable<BravoProjects.Models.Student>

@if (TempData["UserAlert"] != null)
{
    <div class="alert alert-info alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-info-circle-fill"></i> @TempData["UserAlert"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@{
    ViewData["Title"] = "Students List";
    var prevDisabled = !(bool)ViewData["HasPreviousPage"] ? "disabled" : "";
    var nextDisabled = !(bool)ViewData["HasNextPage"] ? "disabled" : "";
}

<h1>Students</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-action="Create" class="btn btn-success">Add New Student</a>
    <span class="text-muted">Page @ViewData["PageIndex"]</span>
</div>

<form asp-action="Create">
</form>

<form asp-action="Index" method="get" class="mb-4">
    <div class="row g-2">
        <div class="col-md-4">
            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Search Name/ID..." />
        </div>

        @if (User.IsInRole("Admin"))
        {
            <div class="col-md-3">
                <select name="branchId" class="form-select shadow-sm" asp-items="ViewBag.BranchList">
                    <option value="">-- All Branches --</option>
                </select>
            </div>
        }

        <div class="col-md-3">
            <select name="courseId" class="form-select shadow-sm" asp-items="ViewBag.CourseList">
                <option value="">-- All Courses --</option>
            </select>
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Filter</button>
        </div>
    </div>
</form>

<table class="table table-striped table-hover border shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>ID Number</th>
            <th>Phone Number</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.FirstName)</td>
                <td>@Html.DisplayFor(modelItem => item.LastName)</td>
                <td>@Html.DisplayFor(modelItem => item.IdNumber)</td>
                <td>@Html.DisplayFor(modelItem => item.PhoneNumber)</td>
                <td class="text-center">
                    <div class="btn-group" role="group">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="d-flex justify-content-center mt-4">
    <a asp-action="Index"
       asp-route-pageNumber="@((int)ViewData["PageIndex"] - 1)"
       asp-route-searchString="@ViewData["CurrentFilter"]"
       asp-route-courseId="@ViewData["CurrentCourse"]"
       class="btn btn-outline-primary me-2 @(!(bool)ViewData["HasPreviousPage"] ? "disabled" : "")">
        &laquo; Previous
    </a>

    <a asp-action="Index"
       asp-route-pageNumber="@((int)ViewData["PageIndex"] + 1)"
       asp-route-searchString="@ViewData["CurrentFilter"]"
       asp-route-courseId="@ViewData["CurrentCourse"]"
       class="btn btn-outline-primary @(!(bool)ViewData["HasNextPage"] ? "disabled" : "")">
        Next &raquo;
    </a>
</div>