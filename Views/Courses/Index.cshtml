@model IEnumerable<BravoProjects.Models.Course>

@{
    ViewData["Title"] = "Courses List";
}

<h1>Courses</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-action="Create" class="btn btn-success">Create New Course</a>
</div>

@* Search Form *@
<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group shadow-sm">
        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
               class="form-control" placeholder="Search by Course Title (e.g. Forklift, EDC)..." />
        <button type="submit" class="btn btn-primary">Search</button>
        <a asp-action="Index" class="btn btn-secondary">Clear</a>
    </div>
</form>

<table class="table table-striped table-hover border shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(model => model.Title)</th>
            <th>@Html.DisplayNameFor(model => model.StandardFee)</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="3" class="text-center text-muted">No courses found matching your search.</td>
            </tr>
        }
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@Html.DisplayFor(modelItem => item.Title)</strong></td>
                <td>@item.StandardFee.ToString("C")</td>
                <td class="text-center">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@* ... existing table code ... *@

<div class="d-flex justify-content-center mt-4">
    <a asp-action="Index"
       asp-route-pageNumber="@((int)ViewData["PageIndex"] - 1)"
       asp-route-searchString="@ViewData["CurrentFilter"]"
       class="btn btn-outline-primary me-2 @(!(bool)ViewData["HasPreviousPage"] ? "disabled" : "")">
        &laquo; Previous
    </a>

    <a asp-action="Index"
       asp-route-pageNumber="@((int)ViewData["PageIndex"] + 1)"
       asp-route-searchString="@ViewData["CurrentFilter"]"
       class="btn btn-outline-primary @(!(bool)ViewData["HasNextPage"] ? "disabled" : "")">
        Next &raquo;
    </a>
</div>