@model BravoProjects.Models.Course

@{
    ViewData["Title"] = "Create Course";
}

<h1>Create</h1>

<h4>Course</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Title" class="control-label fw-bold"></label>
                <input asp-for="Title" class="form-control" placeholder="e.g. TLB / Excavator" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="StandardFee" class="control-label fw-bold"></label>
                <div class="input-group">
                    <span class="input-group-text">R</span>
                    <input asp-for="StandardFee" class="form-control" type="number" step="0.01" />
                </div>
                <span asp-validation-for="StandardFee" class="text-danger"></span>
            </div>

            @* --- NEW FIELD ADDED HERE --- *@
            <div class="form-group mb-4">
                <label asp-for="CourseExpense" class="control-label fw-bold text-danger">Instructor/Running Expense</label>
                <div class="input-group">
                    <span class="input-group-text bg-danger text-white">R</span>
                    <input asp-for="CourseExpense" class="form-control border-danger" type="number" step="0.01" placeholder="e.g. 800.00" />
                </div>
                <small class="text-muted">This amount is subtracted from revenue during cash-up.</small>
                <span asp-validation-for="CourseExpense" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create Course" class="btn btn-primary shadow-sm w-100" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-link">← Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}