@model BravoProjects.Models.Enrollment

@{
    ViewData["Title"] = "Update Payment";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Update Payment: @Model.Course.Title</h4>
        </div>
        <div class="card-body">
            <h5 class="text-muted mb-4">Student: @Model.Student.FirstName @Model.Student.LastName</h5>

            <div class="alert alert-info">
                <strong>Current Status:</strong> @Model.PaymentStatus <br />
                <strong>Already Paid:</strong> @Model.AmountPaid.ToString("C") <br />
                <strong>Course Fee:</strong> @Model.Course.StandardFee.ToString("C")
            </div>

            <form asp-action="AddPayment" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">New Receipt Number</label>
                        <input name="newReceiptNo" class="form-control" required placeholder="Enter receipt for this installment" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Payment Method</label>
                        <select name="method" class="form-select">
                            <option value="CASH">CASH</option>
                            <option value="CARD">CARD</option>
                            <option value="EFT">EFT</option>
                        </select>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Additional Amount Paid (R)</label>
                    <input type="number" name="additionalAmount" class="form-control form-control-lg" step="0.01" required />
                    <small class="text-muted">This will be added to the current R @Model.AmountPaid</small>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-controller="Students" asp-action="Details" asp-route-id="@Model.StudentId" class="btn btn-secondary">Cancel</a>
                    <button type="submit" class="btn btn-success px-5">Confirm Payment</button>
                </div>
            </form>
        </div>
    </div>
</div>