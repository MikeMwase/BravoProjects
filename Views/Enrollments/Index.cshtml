@model IEnumerable<BravoProjects.Models.Enrollment>

@{
    ViewData["Title"] = "Course Performance Summary";
    var reportDate = ViewData["ReportDate"]?.ToString();
    var currentFilter = ViewData["CurrentFilter"]?.ToString();
    var selectedBranch = ViewData["SelectedBranch"]; // Capture the current branch selection

    // Grouping logic for the top financial table
    var courseGroups = Model.GroupBy(e => e.Course.Title)
        .Select(g => new
        {
            Title = g.Key,
            Count = g.Count(),
            Cash = g.Where(e => e.MethodOfPayment == "CASH").Sum(e => e.AmountPaid),
            Card = g.Where(e => e.MethodOfPayment == "CARD").Sum(e => e.AmountPaid),
            TotalExpense = g.Count() * (g.FirstOrDefault()?.Course.CourseExpense ?? 0)
        }).ToList();
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-6 mb-0">Course Performance Summary</h1>
        <div class="text-end">
            <span class="badge bg-primary">@DateTime.Parse(reportDate).ToString("dd MMMM yyyy")</span>
            @if (User.IsInRole("Admin"))
            {
                <span class="badge bg-dark">ADMIN VIEW</span>
            }
        </div>
    </div>

    @* --- FILTER SECTION --- *@
    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body py-2">
            <form asp-action="Index" method="get" class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-bold">View Date</label>
                    <input type="date" name="reportDate" value="@reportDate" class="form-control form-control-sm" />
                </div>

                @if (User.IsInRole("Admin") && ViewBag.Branches != null)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-bold">Filter by Branch</label>
                        @* Ensure name is branchId to match the controller parameter *@
                        <select name="branchId" asp-items="ViewBag.Branches" class="form-select form-select-sm">
                            <option value="">All Branches</option>
                        </select>
                    </div>
                }

                <div class="col-md-4">
                    <button type="submit" class="btn btn-sm btn-primary px-3">Apply Filter</button>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Reset</a>
                </div>
            </form>
        </div>
    </div>

    @* --- MAIN PERFORMANCE TABLE --- *@
    <div class="card shadow-sm border-0 mb-4">
        <div class="table-responsive">
            <table class="table table-bordered align-middle mb-0">
                <thead class="table-dark text-center">
                    <tr>
                        <th class="text-start">Course Title</th>
                        <th style="width: 80px;">Qty</th>
                        <th class="text-success" style="width: 140px;">Cash</th>
                        <th class="text-info" style="width: 140px;">Card</th>
                        <th style="width: 160px;">Total Revenue</th>
                        <th class="text-danger" style="width: 160px;">Course Expenses</th>
                        <th style="width: 160px;">Net Profit</th>
                        <th style="width: 140px;">Actions</th>
                    </tr>
                </thead>
                <tbody class="text-end">
                    @foreach (var g in courseGroups)
                    {
                        var totalRevenue = g.Cash + g.Card;
                        var netProfit = totalRevenue - g.TotalExpense;
                        <tr>
                            <td class="fw-bold text-start">@g.Title</td>
                            <td class="text-center"><span class="badge bg-secondary">@g.Count</span></td>
                            <td class="text-success">@g.Cash.ToString("N2")</td>
                            <td class="text-info">@g.Card.ToString("N2")</td>
                            <td class="fw-bold">@totalRevenue.ToString("N2")</td>
                            <td class="text-danger">(@g.TotalExpense.ToString("N2"))</td>
                            <td class="fw-bold @(netProfit >= 0 ? "text-success" : "text-danger") bg-light">
                                @netProfit.ToString("C")
                            </td>
                            <td class="text-center">
                                @* Included branchId in the route so the drill-down maintains the branch filter *@
                                <a asp-action="Index"
                                   asp-route-reportDate="@reportDate"
                                   asp-route-searchString="@g.Title"
                                   asp-route-branchId="@selectedBranch"
                                   class="btn btn-sm btn-outline-primary py-0">View Students</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* --- CALCULATIONS BLOCK --- *@
    @{
        decimal cashTotal = courseGroups.Sum(x => x.Cash);
        decimal cardTotal = courseGroups.Sum(x => x.Card);
        decimal totalRevenueAll = cashTotal + cardTotal;
        decimal generalExpenses = ViewBag.ExpensesTotal ?? 0;
        decimal courseOverheads = courseGroups.Sum(x => x.TotalExpense);
        decimal finalProfit = totalRevenueAll - generalExpenses - courseOverheads;
    }

    @* --- SUMMARY CARDS --- *@
    <div class="card shadow border-0 bg-dark text-white overflow-hidden mb-4">
        <div class="card-body p-0">
            <div class="row g-0 text-center">
                <div class="col-md-3 py-4 border-end border-secondary">
                    <p class="text-muted mb-1 small">TOTAL REVENUE</p>
                    <h3 class="text-primary fw-bold">@totalRevenueAll.ToString("C")</h3>
                    <div class="small text-muted">Cash: @cashTotal.ToString("N0") | Card: @cardTotal.ToString("N0")</div>
                </div>
                <div class="col-md-3 py-4 border-end border-secondary">
                    <p class="text-muted mb-1 small">GENERAL EXPENSES</p>
                    <h3 class="text-danger">@generalExpenses.ToString("C")</h3>
                    <small class="text-muted">Office/Petty Cash</small>
                </div>
                <div class="col-md-3 py-4 border-end border-secondary">
                    <p class="text-muted mb-1 small">COURSE OVERHEADS</p>
                    <h3 class="text-warning">@courseOverheads.ToString("C")</h3>
                    <small class="text-muted">Instructor & Tool Fees</small>
                </div>
                <div class="col-md-3 py-4 bg-black">
                    <p class="text-white-50 mb-1 small fw-bold">FINAL NET PROFIT</p>
                    <h2 class="@(finalProfit >= 0 ? "text-success" : "text-danger") fw-bold">@finalProfit.ToString("C")</h2>
                    <span class="badge @(finalProfit >= 0 ? "bg-success" : "bg-danger")">@(finalProfit >= 0 ? "SURPLUS" : "DEFICIT")</span>
                </div>
            </div>
        </div>
        <div class="card-footer bg-secondary text-white-50 small d-flex justify-content-between border-0">
            <span><strong>Drawer Check:</strong> Expected Cash: <strong class="text-white">@((cashTotal - generalExpenses).ToString("C"))</strong></span>
            <button class="btn btn-sm btn-light py-0" onclick="window.print()">Print Report</button>
        </div>
    </div>

    @* --- ENROLLMENT DRILL-DOWN --- *@
    @if (!string.IsNullOrEmpty(currentFilter))
    {
        <div class="mt-4 mb-5 border-top pt-4">
            <h4 class="text-secondary mb-3"><i class="bi bi-people-fill"></i> Details for "@currentFilter"</h4>
            <div class="card shadow-sm border-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Receipt</th>
                                <th>Student Name</th>
                                @if (User.IsInRole("Admin"))
                                {
                                    <th>Branch</th>
                                }
                                <th>Method</th>
                                <th class="text-end pe-3">Amount Paid</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var enrollment in Model)
                            {
                                <tr>
                                    <td class="ps-3 fw-bold">@enrollment.ReceiptNo</td>
                                    <td>@enrollment.Student.FirstName @enrollment.Student.LastName</td>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <td><span class="badge bg-info text-dark">@(enrollment.Student.Branch?.Name ?? "N/A")</span></td>
                                    }
                                    <td>@enrollment.MethodOfPayment</td>
                                    <td class="text-end pe-3 fw-bold text-primary">@enrollment.AmountPaid.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}